{
  "id": "frame-kpi",
  "type": "frame",
  "data": {
    "title": "📊 KPI Overview",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>KPI Overview</title>\n<style>\n  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}\n  @keyframes fadeInUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}\n  @keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}\n  @keyframes pulse{0%,100%{opacity:.6}50%{opacity:1}}\n  @keyframes countUp{from{opacity:0;transform:scale(.8)}to{opacity:1;transform:scale(1)}}\n  @keyframes gradientShift{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}\n  @keyframes glowPulse{0%,100%{box-shadow:0 0 20px rgba(102,126,234,.15)}50%{box-shadow:0 0 40px rgba(102,126,234,.3)}}\n\n  body{\n    font-family:'Segoe UI',system-ui,-apple-system,sans-serif;\n    background:#0f0f23;\n    color:#e0e0e0;\n    min-height:100vh;\n    overflow:hidden;\n    position:relative;\n  }\n  body::before{\n    content:'';position:fixed;top:-50%;left:-50%;width:200%;height:200%;\n    background:radial-gradient(ellipse at 30% 20%,rgba(102,126,234,.08) 0%,transparent 50%),\n               radial-gradient(ellipse at 70% 80%,rgba(118,75,162,.06) 0%,transparent 50%);\n    pointer-events:none;z-index:0;\n  }\n\n  .dashboard{\n    display:grid;\n    grid-template-columns:repeat(2,1fr);\n    gap:20px;\n    padding:24px;\n    height:100vh;\n    position:relative;z-index:1;\n  }\n\n  .card{\n    background:rgba(255,255,255,.04);\n    backdrop-filter:blur(20px);\n    -webkit-backdrop-filter:blur(20px);\n    border:1px solid rgba(255,255,255,.08);\n    border-radius:20px;\n    padding:28px;\n    position:relative;\n    overflow:hidden;\n    cursor:default;\n    animation:fadeInUp .7s ease-out both;\n    transition:all .4s cubic-bezier(.25,.46,.45,.94);\n    display:flex;flex-direction:column;justify-content:space-between;\n  }\n  .card:nth-child(1){animation-delay:.1s}\n  .card:nth-child(2){animation-delay:.2s}\n  .card:nth-child(3){animation-delay:.3s}\n  .card:nth-child(4){animation-delay:.4s}\n\n  .card::before{\n    content:'';position:absolute;top:0;left:0;right:0;height:3px;\n    background:linear-gradient(90deg,#667eea,#764ba2);\n    opacity:.8;transition:opacity .3s;\n  }\n  .card::after{\n    content:'';position:absolute;inset:0;\n    background:linear-gradient(135deg,rgba(102,126,234,.06) 0%,rgba(118,75,162,.03) 100%);\n    pointer-events:none;border-radius:20px;\n  }\n\n  .card:hover{\n    transform:translateY(-4px);\n    border-color:rgba(102,126,234,.3);\n    animation:glowPulse 2s ease-in-out infinite;\n  }\n  .card:hover::before{opacity:1}\n\n  .card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;position:relative;z-index:1}\n\n  .card-icon{\n    width:44px;height:44px;border-radius:14px;\n    background:linear-gradient(135deg,rgba(102,126,234,.2),rgba(118,75,162,.2));\n    display:flex;align-items:center;justify-content:center;\n    font-size:20px;\n    border:1px solid rgba(102,126,234,.15);\n  }\n\n  .card-badge{\n    font-size:11px;font-weight:600;\n    padding:4px 10px;border-radius:20px;\n    background:rgba(102,126,234,.15);\n    color:#a5b4fc;letter-spacing:.3px;\n  }\n  .card-badge.up{background:rgba(52,211,153,.12);color:#6ee7b7}\n  .card-badge.neutral{background:rgba(251,191,36,.12);color:#fcd34d}\n\n  .card-label{\n    font-size:12px;font-weight:500;color:#8888aa;\n    text-transform:uppercase;letter-spacing:1.2px;\n    margin-bottom:4px;position:relative;z-index:1;\n  }\n\n  .card-value{\n    font-size:42px;font-weight:700;\n    background:linear-gradient(135deg,#e0e7ff,#c4b5fd);\n    -webkit-background-clip:text;-webkit-text-fill-color:transparent;\n    background-clip:text;\n    line-height:1.1;\n    position:relative;z-index:1;\n    animation:countUp .6s ease-out both;\n  }\n\n  .card-sub{font-size:12px;color:#6b6b8d;margin-top:2px;position:relative;z-index:1}\n\n  .sparkline-container{\n    margin-top:12px;height:40px;position:relative;z-index:1;\n    opacity:.7;transition:opacity .3s;\n  }\n  .card:hover .sparkline-container{opacity:1}\n\n  .sparkline{display:flex;align-items:flex-end;gap:3px;height:100%}\n  .spark-bar{\n    flex:1;border-radius:3px 3px 0 0;\n    background:linear-gradient(to top,rgba(102,126,234,.3),rgba(118,75,162,.5));\n    transition:all .3s;min-width:4px;\n  }\n  .card:hover .spark-bar{background:linear-gradient(to top,rgba(102,126,234,.5),rgba(118,75,162,.8))}\n\n  .sparkline-line{position:absolute;inset:0}\n  .sparkline-line svg{width:100%;height:100%}\n  .sparkline-line path{\n    fill:none;stroke:url(#sparkGrad);stroke-width:2;\n    stroke-linecap:round;stroke-linejoin:round;\n  }\n  .sparkline-line .area{\n    fill:url(#sparkAreaGrad);stroke:none;opacity:.3;\n  }\n</style>\n</head>\n<body>\n<svg width=\"0\" height=\"0\" style=\"position:absolute\">\n  <defs>\n    <linearGradient id=\"sparkGrad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n      <stop offset=\"0%\" stop-color=\"#667eea\"/>\n      <stop offset=\"100%\" stop-color=\"#764ba2\"/>\n    </linearGradient>\n    <linearGradient id=\"sparkAreaGrad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n      <stop offset=\"0%\" stop-color=\"#667eea\" stop-opacity=\".4\"/>\n      <stop offset=\"100%\" stop-color=\"#667eea\" stop-opacity=\"0\"/>\n    </linearGradient>\n  </defs>\n</svg>\n\n<div class=\"dashboard\">\n  <!-- Total Candidates -->\n  <div class=\"card\" id=\"card-total\">\n    <div>\n      <div class=\"card-header\">\n        <div class=\"card-icon\">👥</div>\n        <div class=\"card-badge up\">▲ Active</div>\n      </div>\n      <div class=\"card-label\">Total Candidates</div>\n      <div class=\"card-value\" data-target=\"6\">0</div>\n      <div class=\"card-sub\">Currently in pipeline</div>\n    </div>\n    <div class=\"sparkline-container\">\n      <div class=\"sparkline\" id=\"spark-total\"></div>\n    </div>\n  </div>\n\n  <!-- Avg Score -->\n  <div class=\"card\" id=\"card-score\">\n    <div>\n      <div class=\"card-header\">\n        <div class=\"card-icon\">📊</div>\n        <div class=\"card-badge up\">▲ Good</div>\n      </div>\n      <div class=\"card-label\">Average Score</div>\n      <div class=\"card-value\" data-target=\"77.3\" data-decimal=\"1\">0</div>\n      <div class=\"card-sub\">Across all evaluations</div>\n    </div>\n    <div class=\"sparkline-container\">\n      <div class=\"sparkline-line\" id=\"spark-score\"></div>\n    </div>\n  </div>\n\n  <!-- Strong Matches -->\n  <div class=\"card\" id=\"card-match\">\n    <div>\n      <div class=\"card-header\">\n        <div class=\"card-icon\">🎯</div>\n        <div class=\"card-badge up\">50%</div>\n      </div>\n      <div class=\"card-label\">Strong Matches</div>\n      <div class=\"card-value\" data-target=\"3\">0</div>\n      <div class=\"card-sub\">Out of 6 evaluated candidates</div>\n    </div>\n    <div class=\"sparkline-container\">\n      <div class=\"sparkline\" id=\"spark-match\"></div>\n    </div>\n  </div>\n\n  <!-- Pipeline Conversion -->\n  <div class=\"card\" id=\"card-convert\">\n    <div>\n      <div class=\"card-header\">\n        <div class=\"card-icon\">🚀</div>\n        <div class=\"card-badge neutral\">Steady</div>\n      </div>\n      <div class=\"card-label\">Pipeline Conversion</div>\n      <div class=\"card-value\" data-target=\"83\" data-suffix=\"%\">0</div>\n      <div class=\"card-sub\">Candidates advancing forward</div>\n    </div>\n    <div class=\"sparkline-container\">\n      <div class=\"sparkline-line\" id=\"spark-convert\"></div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Animated counters\n  function animateCounters(){\n    document.querySelectorAll('.card-value').forEach(el=>{\n      const target=parseFloat(el.dataset.target);\n      const decimal=parseInt(el.dataset.decimal)||0;\n      const suffix=el.dataset.suffix||'';\n      const duration=1800;\n      const start=performance.now();\n      function tick(now){\n        const elapsed=now-start;\n        const progress=Math.min(elapsed/duration,1);\n        const eased=1-Math.pow(1-progress,4);\n        const current=eased*target;\n        el.textContent=(decimal?current.toFixed(decimal):Math.round(current))+suffix;\n        if(progress<1)requestAnimationFrame(tick);\n      }\n      requestAnimationFrame(tick);\n    });\n  }\n\n  // Bar sparklines\n  function createBarSparkline(id,data){\n    const container=document.getElementById(id);\n    if(!container)return;\n    const max=Math.max(...data);\n    data.forEach((v,i)=>{\n      const bar=document.createElement('div');\n      bar.className='spark-bar';\n      bar.style.height=(v/max*100)+'%';\n      bar.style.animationDelay=(i*0.05)+'s';\n      container.appendChild(bar);\n    });\n  }\n\n  // Line sparklines\n  function createLineSparkline(id,data){\n    const container=document.getElementById(id);\n    if(!container)return;\n    const w=200,h=40;\n    const max=Math.max(...data),min=Math.min(...data);\n    const range=max-min||1;\n    const points=data.map((v,i)=>{\n      const x=(i/(data.length-1))*w;\n      const y=h-((v-min)/range)*h*0.85-2;\n      return{x,y};\n    });\n    const pathD=points.map((p,i)=>((i===0?'M':'L')+p.x+','+p.y)).join(' ');\n    const areaD=pathD+' L'+w+','+h+' L0,'+h+' Z';\n    const svg=document.createElementNS('http://www.w3.org/2000/svg','svg');\n    svg.setAttribute('viewBox','0 0 '+w+' '+h);\n    svg.setAttribute('preserveAspectRatio','none');\n    svg.style.width='100%';svg.style.height='100%';\n\n    const area=document.createElementNS('http://www.w3.org/2000/svg','path');\n    area.setAttribute('d',areaD);area.classList.add('area');\n    const line=document.createElementNS('http://www.w3.org/2000/svg','path');\n    line.setAttribute('d',pathD);\n\n    svg.appendChild(area);svg.appendChild(line);\n    container.appendChild(svg);\n  }\n\n  // Init\n  setTimeout(animateCounters,300);\n  createBarSparkline('spark-total',[2,3,4,3,5,4,6,5,6]);\n  createLineSparkline('spark-score',[62,68,71,74,70,73,75,77,77.3]);\n  createBarSparkline('spark-match',[1,1,2,2,2,3,3,3,3]);\n  createLineSparkline('spark-convert',[70,72,78,80,75,82,85,83,83]);\n\n  // Jetro refresh listener\n  window.addEventListener('jet:refresh',(e)=>{\n    const d=e.detail||{};\n    if(d.totalCandidates!==undefined){\n      const el=document.querySelector('#card-total .card-value');\n      el.dataset.target=d.totalCandidates;\n    }\n    if(d.avgScore!==undefined){\n      const el=document.querySelector('#card-score .card-value');\n      el.dataset.target=d.avgScore;\n    }\n    if(d.strongMatches!==undefined){\n      const el=document.querySelector('#card-match .card-value');\n      el.dataset.target=d.strongMatches;\n    }\n    if(d.conversion!==undefined){\n      const el=document.querySelector('#card-convert .card-value');\n      el.dataset.target=d.conversion;\n    }\n    animateCounters();\n  });\n})();\n</script>\n</body>\n</html>\n"
  },
