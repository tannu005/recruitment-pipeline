  "data": {
    "title": "🔥 Skills Heatmap",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Skills Heatmap</title>\n<script src=\"https://cdn.plot.ly/plotly-2.35.2.min.js\"></script>\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body {\n    background: #0f0f23;\n    color: #e0e0e0;\n    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n    min-height: 100vh;\n    padding: 12px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  .header {\n    text-align: center;\n    margin-bottom: 8px;\n    width: 100%;\n  }\n  .header h2 {\n    font-size: 14px;\n    font-weight: 600;\n    background: linear-gradient(135deg, #667eea, #764ba2);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    letter-spacing: 0.5px;\n  }\n  #heatmap {\n    width: 100%;\n    height: calc(100vh - 60px);\n    min-height: 280px;\n  }\n</style>\n</head>\n<body>\n  <div class=\"header\">\n    <h2>SKILLS GAP ANALYSIS</h2>\n  </div>\n  <div id=\"heatmap\"></div>\n  \n  <script>\n    const candidates = ['John D.(1)', 'John D.(2)', 'Tannu(1)', 'Uio', 'John D.(3)', 'Tannu(2)'];\n    const skills = ['Node.js', 'React', 'PostgreSQL', 'Kubernetes', 'TypeScript'];\n    \n    // Skill match data based on actual evaluation scores\n    // 1 = has skill, 0.5 = partial, 0 = missing\n    const z = [\n      [1,   1,   1,   0,   0.7],  // John Doe 1 - 92% skill\n      [1,   1,   1,   0,   0.7],  // John Doe 2 - 92% skill\n      [1,   1,   1,   0.5, 0.8],  // Tannu 1 - 100% skill\n      [0,   0,   0,   0,   0  ],  // Uio - 0% skill\n      [1,   1,   1,   0.3, 0.8],  // John Doe 3 - 100% skill\n      [1,   1,   0,   0,   0.5],  // Tannu 2 - 67% skill\n    ];\n    \n    // Custom annotations\n    const annotations = [];\n    for (let i = 0; i < candidates.length; i++) {\n      for (let j = 0; j < skills.length; j++) {\n        const val = z[i][j];\n        annotations.push({\n          x: skills[j],\n          y: candidates[i],\n          text: val >= 0.8 ? '✓' : val >= 0.3 ? '~' : '✗',\n          font: {\n            color: val >= 0.8 ? '#10b981' : val >= 0.3 ? '#f59e0b' : '#ef4444',\n            size: 14,\n            family: 'system-ui'\n          },\n          showarrow: false\n        });\n      }\n    }\n    \n    const data = [{\n      z: z,\n      x: skills,\n      y: candidates,\n      type: 'heatmap',\n      colorscale: [\n        [0,    '#1a0a2e'],\n        [0.25, '#3b1261'],\n        [0.5,  '#764ba2'],\n        [0.75, '#667eea'],\n        [1,    '#10b981']\n      ],\n      showscale: true,\n      colorbar: {\n        title: { text: 'Match', font: { color: '#94a3b8', size: 10 } },\n        tickfont: { color: '#94a3b8', size: 9 },\n        len: 0.6,\n        thickness: 12,\n        outlinewidth: 0\n      },\n      hoverongaps: false,\n      hovertemplate: '<b>%{y}</b><br>%{x}: %{z:.0%}<extra></extra>'\n    }];\n    \n    const layout = {\n      paper_bgcolor: '#0f0f23',\n      plot_bgcolor: '#0f0f23',\n      font: { color: '#e0e0e0', family: 'system-ui', size: 10 },\n      margin: { l: 80, r: 40, t: 10, b: 50 },\n      xaxis: {\n        side: 'bottom',\n        tickangle: -30,\n        tickfont: { size: 10, color: '#94a3b8' },\n        gridcolor: 'rgba(255,255,255,0.03)'\n      },\n      yaxis: {\n        autorange: 'reversed',\n        tickfont: { size: 9, color: '#94a3b8' },\n        gridcolor: 'rgba(255,255,255,0.03)'\n      },\n      annotations: annotations\n    };\n    \n    const config = {\n      responsive: true,\n      displayModeBar: false\n    };\n    \n    Plotly.newPlot('heatmap', data, layout, config);\n    \n    window.addEventListener('jet:refresh', (e) => {\n      const detail = e.detail;\n      if (detail && detail.heatmapData) {\n        Plotly.restyle('heatmap', { z: [detail.heatmapData] });\n      }\n    });\n  </script>\n</body>\n</html>\n"
  },
