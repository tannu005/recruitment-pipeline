{
  "id": "frame-ranking",
  "type": "frame",
  "data": {
    "title": "🏆 Candidate Rankings",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Candidate Ranking</title>\n<style>\n  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}\n  @keyframes fadeInRow{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:translateX(0)}}\n  @keyframes slideDown{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}\n\n  body{\n    font-family:'Segoe UI',system-ui,-apple-system,sans-serif;\n    background:#0f0f23;color:#d1d5db;\n    min-height:100vh;padding:20px;overflow-x:hidden;\n  }\n\n  .header{\n    display:flex;align-items:center;justify-content:space-between;\n    margin-bottom:16px;animation:slideDown .5s ease-out;\n  }\n  .header h2{\n    font-size:16px;font-weight:600;\n    background:linear-gradient(135deg,#e0e7ff,#c4b5fd);\n    -webkit-background-clip:text;-webkit-text-fill-color:transparent;\n    background-clip:text;\n  }\n  .header .count{\n    font-size:12px;color:#6b6b8d;\n    background:rgba(102,126,234,.1);\n    padding:4px 12px;border-radius:20px;\n    border:1px solid rgba(102,126,234,.15);\n  }\n\n  .search-bar{\n    position:relative;margin-bottom:16px;\n    animation:slideDown .5s ease-out .1s both;\n  }\n  .search-bar input{\n    width:100%;padding:10px 16px 10px 40px;\n    background:rgba(255,255,255,.04);\n    border:1px solid rgba(255,255,255,.08);\n    border-radius:12px;color:#e0e0e0;\n    font-size:13px;outline:none;\n    transition:all .3s;\n  }\n  .search-bar input:focus{\n    border-color:rgba(102,126,234,.4);\n    background:rgba(255,255,255,.06);\n    box-shadow:0 0 20px rgba(102,126,234,.1);\n  }\n  .search-bar input::placeholder{color:#4a4a6a}\n  .search-bar .icon{\n    position:absolute;left:14px;top:50%;transform:translateY(-50%);\n    font-size:14px;color:#6b6b8d;pointer-events:none;\n  }\n\n  .table-container{\n    background:rgba(255,255,255,.02);\n    border:1px solid rgba(255,255,255,.06);\n    border-radius:16px;overflow:hidden;\n  }\n\n  table{width:100%;border-collapse:collapse}\n\n  thead th{\n    padding:12px 14px;text-align:left;\n    font-size:11px;font-weight:600;\n    text-transform:uppercase;letter-spacing:.8px;\n    color:#6b6b8d;\n    background:rgba(255,255,255,.03);\n    border-bottom:1px solid rgba(255,255,255,.06);\n    position:sticky;top:0;\n  }\n\n  tbody tr{\n    border-bottom:1px solid rgba(255,255,255,.03);\n    transition:all .3s;\n    animation:fadeInRow .5s ease-out both;\n  }\n  tbody tr:nth-child(1){animation-delay:.15s}\n  tbody tr:nth-child(2){animation-delay:.22s}\n  tbody tr:nth-child(3){animation-delay:.29s}\n  tbody tr:nth-child(4){animation-delay:.36s}\n  tbody tr:nth-child(5){animation-delay:.43s}\n  tbody tr:nth-child(6){animation-delay:.50s}\n\n  tbody tr:nth-child(even){background:rgba(255,255,255,.015)}\n  tbody tr:hover{background:rgba(102,126,234,.08)!important}\n\n  td{padding:12px 14px;font-size:13px;white-space:nowrap}\n\n  .rank{\n    width:36px;height:36px;border-radius:10px;\n    display:flex;align-items:center;justify-content:center;\n    font-weight:700;font-size:14px;\n  }\n  .rank-1{background:linear-gradient(135deg,rgba(250,204,21,.2),rgba(245,158,11,.2));color:#fcd34d;border:1px solid rgba(250,204,21,.2)}\n  .rank-2{background:linear-gradient(135deg,rgba(156,163,175,.2),rgba(107,114,128,.2));color:#d1d5db;border:1px solid rgba(156,163,175,.2)}\n  .rank-3{background:linear-gradient(135deg,rgba(180,83,9,.2),rgba(217,119,6,.2));color:#fbbf24;border:1px solid rgba(180,83,9,.2)}\n  .rank-default{background:rgba(255,255,255,.05);color:#6b6b8d;border:1px solid rgba(255,255,255,.05)}\n\n  .name-cell{display:flex;align-items:center;gap:10px}\n  .avatar{\n    width:32px;height:32px;border-radius:10px;\n    background:linear-gradient(135deg,#667eea,#764ba2);\n    display:flex;align-items:center;justify-content:center;\n    font-size:13px;font-weight:600;color:#fff;\n    flex-shrink:0;\n  }\n  .name-text{font-weight:500;color:#e0e7ff}\n\n  .score-cell{display:flex;align-items:center;gap:10px}\n  .score-num{font-weight:700;font-size:15px;min-width:28px}\n  .score-bar-bg{\n    flex:1;height:6px;border-radius:3px;\n    background:rgba(255,255,255,.06);\n    min-width:50px;max-width:80px;overflow:hidden;\n  }\n  .score-bar-fill{\n    height:100%;border-radius:3px;\n    transition:width 1s ease-out;\n  }\n\n  .badge{\n    display:inline-flex;align-items:center;gap:4px;\n    padding:4px 10px;border-radius:20px;\n    font-size:11px;font-weight:600;letter-spacing:.3px;\n  }\n  .badge-strong{background:rgba(52,211,153,.12);color:#6ee7b7;border:1px solid rgba(52,211,153,.15)}\n  .badge-good{background:rgba(250,204,21,.12);color:#fcd34d;border:1px solid rgba(250,204,21,.15)}\n  .badge-potential{background:rgba(251,146,60,.12);color:#fb923c;border:1px solid rgba(251,146,60,.15)}\n  .badge-poor{background:rgba(248,113,113,.12);color:#fca5a5;border:1px solid rgba(248,113,113,.15)}\n\n  .badge::before{\n    content:'';width:6px;height:6px;border-radius:50%;\n  }\n  .badge-strong::before{background:#34d399}\n  .badge-good::before{background:#fbbf24}\n  .badge-potential::before{background:#fb923c}\n  .badge-poor::before{background:#f87171}\n\n  .pct{color:#a5b4fc;font-weight:500}\n  .rec{font-size:12px;color:#8888aa;max-width:180px;white-space:normal;line-height:1.4}\n\n  .no-results{\n    text-align:center;padding:40px;color:#4a4a6a;\n    font-size:14px;display:none;\n  }\n</style>\n</head>\n<body>\n<div class=\"header\">\n  <h2>Candidate Ranking</h2>\n  <div class=\"count\" id=\"countBadge\">6 candidates</div>\n</div>\n\n<div class=\"search-bar\">\n  <span class=\"icon\">🔍</span>\n  <input type=\"text\" id=\"searchInput\" placeholder=\"Search candidates by name, status, or recommendation...\" />\n</div>\n\n<div class=\"table-container\">\n  <table>\n    <thead>\n      <tr>\n        <th>Rank</th>\n        <th>Name</th>\n        <th>Score</th>\n        <th>Status</th>\n        <th>Skill Match</th>\n        <th>Culture Fit</th>\n        <th>Recommendation</th>\n      </tr>\n    </thead>\n    <tbody id=\"tableBody\"></tbody>\n  </table>\n  <div class=\"no-results\" id=\"noResults\">No candidates match your search.</div>\n</div>\n\n<script>\n(function(){\n  const candidates=[\n    {rank:1,name:\"John Doe\",score:88,status:\"Strong Match\",statusClass:\"strong\",skill:92,culture:85,rec:\"Move to technical interview\"},\n    {rank:2,name:\"John Doe\",score:88,status:\"Strong Match\",statusClass:\"strong\",skill:92,culture:85,rec:\"Move to technical interview\"},\n    {rank:3,name:\"tannu\",score:87,status:\"Strong Match\",statusClass:\"strong\",skill:100,culture:74,rec:\"Move to technical interview\"},\n    {rank:4,name:\"John Doe\",score:82,status:\"Good Match\",statusClass:\"good\",skill:100,culture:74,rec:\"Consider for technical interview\"},\n    {rank:5,name:\"tannu\",score:64,status:\"Potential Match\",statusClass:\"potential\",skill:67,culture:74,rec:\"Conduct short HR screening\"},\n    {rank:6,name:\"uio\",score:55,status:\"Poor Match\",statusClass:\"poor\",skill:0,culture:74,rec:\"Do not advance\"},\n  ];\n\n  function getInitials(n){return n.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2)}\n  function getRankClass(r){return r<=3?'rank-'+r:'rank-default'}\n  function scoreColor(s){\n    if(s>=85)return'#34d399';\n    if(s>=75)return'#fbbf24';\n    if(s>=60)return'#fb923c';\n    return'#f87171';\n  }\n\n  function renderTable(data){\n    const tbody=document.getElementById('tableBody');\n    const noRes=document.getElementById('noResults');\n    const badge=document.getElementById('countBadge');\n    tbody.innerHTML='';\n    if(data.length===0){noRes.style.display='block';badge.textContent='0 candidates';return;}\n    noRes.style.display='none';\n    badge.textContent=data.length+' candidate'+(data.length!==1?'s':'');\n\n    data.forEach((c,i)=>{\n      const tr=document.createElement('tr');\n      tr.style.animationDelay=(i*0.07+0.1)+'s';\n      tr.innerHTML=`\n        <td><div class=\"rank ${getRankClass(c.rank)}\">${c.rank}</div></td>\n        <td><div class=\"name-cell\"><div class=\"avatar\">${getInitials(c.name)}</div><span class=\"name-text\">${c.name}</span></div></td>\n        <td><div class=\"score-cell\"><span class=\"score-num\" style=\"color:${scoreColor(c.score)}\">${c.score}</span><div class=\"score-bar-bg\"><div class=\"score-bar-fill\" style=\"width:${c.score}%;background:${scoreColor(c.score)}\"></div></div></div></td>\n        <td><span class=\"badge badge-${c.statusClass}\">${c.status}</span></td>\n        <td><span class=\"pct\">${c.skill}%</span></td>\n        <td><span class=\"pct\">${c.culture}%</span></td>\n        <td><span class=\"rec\">${c.rec}</span></td>\n      `;\n      tbody.appendChild(tr);\n    });\n  }\n\n  renderTable(candidates);\n\n  document.getElementById('searchInput').addEventListener('input',function(){\n    const q=this.value.toLowerCase().trim();\n    if(!q){renderTable(candidates);return;}\n    const filtered=candidates.filter(c=>\n      c.name.toLowerCase().includes(q)||\n      c.status.toLowerCase().includes(q)||\n      c.rec.toLowerCase().includes(q)||\n      String(c.score).includes(q)\n    );\n    renderTable(filtered);\n  });\n\n  window.addEventListener('jet:refresh',(e)=>{\n    const d=e.detail;\n    if(d&&d.candidates){\n      candidates.length=0;\n      d.candidates.forEach(c=>candidates.push(c));\n      renderTable(candidates);\n    }\n  });\n})();\n</script>\n</body>\n</html>\n"
  },
