{
  "id": "frame-scores",
  "type": "frame",
  "data": {
    "title": "📈 Score Breakdown",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Score Breakdown</title>\n<script src=\"https://cdn.plot.ly/plotly-2.35.2.min.js\"></script>\n<style>\n  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}\n  @keyframes fadeIn{from{opacity:0}to{opacity:1}}\n\n  body{\n    font-family:'Segoe UI',system-ui,-apple-system,sans-serif;\n    background:#0f0f23;color:#d1d5db;\n    min-height:100vh;overflow:hidden;\n  }\n\n  .container{\n    display:grid;\n    grid-template-columns:1fr 1fr;\n    gap:0;\n    height:100vh;\n    animation:fadeIn .6s ease-out;\n  }\n\n  .panel{\n    padding:16px;\n    display:flex;flex-direction:column;\n    position:relative;\n  }\n  .panel:first-child{\n    border-right:1px solid rgba(255,255,255,.05);\n  }\n\n  .panel-title{\n    font-size:13px;font-weight:600;\n    text-transform:uppercase;letter-spacing:1px;\n    color:#8888aa;margin-bottom:8px;\n    display:flex;align-items:center;gap:8px;\n  }\n  .panel-title::before{\n    content:'';width:3px;height:14px;border-radius:2px;\n    background:linear-gradient(180deg,#667eea,#764ba2);\n  }\n\n  .chart-area{flex:1;min-height:0}\n\n  #radarChart,#barChart{width:100%;height:100%}\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <div class=\"panel\">\n    <div class=\"panel-title\">Average Dimension Scores</div>\n    <div class=\"chart-area\" id=\"radarChart\"></div>\n  </div>\n  <div class=\"panel\">\n    <div class=\"panel-title\">Candidate Overall Scores</div>\n    <div class=\"chart-area\" id=\"barChart\"></div>\n  </div>\n</div>\n\n<script>\n(function(){\n  const candidates=[\n    {name:'John Doe (#1)',score:88,status:'Strong Match',color:'#34d399'},\n    {name:'John Doe (#2)',score:88,status:'Strong Match',color:'#34d399'},\n    {name:'tannu (#3)',score:87,status:'Strong Match',color:'#34d399'},\n    {name:'John Doe (#4)',score:82,status:'Good Match',color:'#fbbf24'},\n    {name:'tannu (#5)',score:64,status:'Potential Match',color:'#fb923c'},\n    {name:'uio (#6)',score:55,status:'Poor Match',color:'#f87171'},\n  ];\n\n  const dimensions=['Skill Match','Experience','Culture Fit','Risk Assessment'];\n  const avgScores=[75.2,72.0,77.7,80.5];\n\n  // ---- Radar Chart ----\n  const radarData=[{\n    type:'scatterpolar',\n    r:[...avgScores,avgScores[0]],\n    theta:[...dimensions,dimensions[0]],\n    fill:'toself',\n    fillcolor:'rgba(102,126,234,.15)',\n    line:{color:'#667eea',width:2.5},\n    marker:{size:7,color:'#a5b4fc',line:{color:'#667eea',width:2}},\n    hovertemplate:'%{theta}: %{r:.1f}<extra></extra>',\n    name:'Avg Score',\n  }];\n\n  const radarLayout={\n    polar:{\n      bgcolor:'transparent',\n      angularaxis:{\n        linecolor:'rgba(255,255,255,.08)',\n        gridcolor:'rgba(255,255,255,.06)',\n        tickfont:{color:'#a5b4fc',size:11,family:'Segoe UI'},\n      },\n      radialaxis:{\n        visible:true,range:[0,100],\n        linecolor:'rgba(255,255,255,.05)',\n        gridcolor:'rgba(255,255,255,.04)',\n        tickfont:{color:'#6b6b8d',size:10},\n        tickvals:[20,40,60,80,100],\n      },\n    },\n    paper_bgcolor:'transparent',\n    plot_bgcolor:'transparent',\n    margin:{t:30,r:40,b:30,l:40},\n    showlegend:false,\n    font:{family:'Segoe UI',color:'#d1d5db'},\n  };\n\n  Plotly.newPlot('radarChart',radarData,radarLayout,{\n    responsive:true,displayModeBar:false,\n  });\n\n  // ---- Horizontal Bar Chart ----\n  const sorted=[...candidates].sort((a,b)=>a.score-b.score);\n\n  const barData=[{\n    type:'bar',\n    y:sorted.map(c=>c.name),\n    x:sorted.map(c=>c.score),\n    orientation:'h',\n    marker:{\n      color:sorted.map(c=>c.color),\n      line:{color:sorted.map(c=>c.color.replace(')',',0.6)').replace('rgb','rgba')),width:0},\n      opacity:0.85,\n    },\n    text:sorted.map(c=>c.score+' — '+c.status),\n    textposition:'inside',\n    textfont:{color:'#fff',size:12,family:'Segoe UI'},\n    insidetextanchor:'end',\n    hovertemplate:'%{y}<br>Score: %{x}<extra></extra>',\n  }];\n\n  const barLayout={\n    paper_bgcolor:'transparent',\n    plot_bgcolor:'transparent',\n    margin:{t:10,r:20,b:40,l:100},\n    xaxis:{\n      range:[0,100],\n      gridcolor:'rgba(255,255,255,.04)',\n      zerolinecolor:'rgba(255,255,255,.06)',\n      tickfont:{color:'#6b6b8d',size:11},\n      title:{text:'Overall Score',font:{color:'#6b6b8d',size:11}},\n    },\n    yaxis:{\n      tickfont:{color:'#a5b4fc',size:12,family:'Segoe UI'},\n      automargin:true,\n    },\n    bargap:0.25,\n    font:{family:'Segoe UI',color:'#d1d5db'},\n    showlegend:false,\n  };\n\n  Plotly.newPlot('barChart',barData,barLayout,{\n    responsive:true,displayModeBar:false,\n  });\n\n  // Jetro refresh\n  window.addEventListener('jet:refresh',(e)=>{\n    const d=e.detail||{};\n    if(d.avgScores){\n      const newR=[...d.avgScores,d.avgScores[0]];\n      Plotly.restyle('radarChart',{r:[newR]});\n    }\n    if(d.candidates){\n      const s=[...d.candidates].sort((a,b)=>a.score-b.score);\n      Plotly.restyle('barChart',{\n        y:[s.map(c=>c.name)],\n        x:[s.map(c=>c.score)],\n        'marker.color':[s.map(c=>c.color)],\n        text:[s.map(c=>c.score+' — '+c.status)],\n      });\n    }\n  });\n})();\n</script>\n</body>\n</html>\n"
  },
