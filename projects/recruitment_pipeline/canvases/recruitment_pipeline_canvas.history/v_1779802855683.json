      "data": {
        "title": "🔻 Pipeline Funnel",
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Pipeline Funnel</title>\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body {\n    background: #0f0f23;\n    color: #e0e0e0;\n    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n    min-height: 100vh;\n    padding: 20px;\n  }\n  .header {\n    text-align: center;\n    margin-bottom: 20px;\n  }\n  .header h2 {\n    font-size: 16px;\n    font-weight: 600;\n    background: linear-gradient(135deg, #667eea, #764ba2);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    letter-spacing: 0.5px;\n  }\n  .funnel-container {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 0;\n    max-width: 340px;\n    margin: 0 auto;\n  }\n  .funnel-stage {\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    height: 52px;\n    border-radius: 6px;\n    color: #fff;\n    font-weight: 600;\n    font-size: 13px;\n    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n    opacity: 0;\n    transform: scaleX(0.3);\n    animation: funnelIn 0.6s ease-out forwards;\n    cursor: pointer;\n    overflow: hidden;\n  }\n  .funnel-stage::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(90deg, rgba(255,255,255,0.08) 0%, transparent 100%);\n    opacity: 0;\n    transition: opacity 0.3s;\n  }\n  .funnel-stage:hover::before { opacity: 1; }\n  .funnel-stage:hover { transform: scaleX(1.03); filter: brightness(1.15); }\n  .funnel-stage:nth-child(1)  { width: 100%; background: linear-gradient(135deg, #667eea, #5a67d8); animation-delay: 0.1s; }\n  .funnel-stage:nth-child(3)  { width: 100%; background: linear-gradient(135deg, #5a67d8, #6366f1); animation-delay: 0.2s; }\n  .funnel-stage:nth-child(5)  { width: 70%;  background: linear-gradient(135deg, #10b981, #059669); animation-delay: 0.3s; }\n  .funnel-stage:nth-child(7)  { width: 45%;  background: linear-gradient(135deg, #f59e0b, #d97706); animation-delay: 0.4s; }\n  .funnel-stage:nth-child(9)  { width: 30%;  background: linear-gradient(135deg, #f97316, #ea580c); animation-delay: 0.5s; }\n  .funnel-stage:nth-child(11) { width: 18%;  background: linear-gradient(135deg, #ef4444, #dc2626); animation-delay: 0.6s; }\n  \n  @keyframes funnelIn {\n    to { opacity: 1; transform: scaleX(1); }\n  }\n  \n  .stage-label {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    width: 100%;\n    padding: 0 16px;\n    z-index: 1;\n  }\n  .stage-name { font-size: 12px; white-space: nowrap; }\n  .stage-count {\n    font-size: 18px;\n    font-weight: 700;\n    min-width: 28px;\n    text-align: right;\n  }\n  \n  .conversion-arrow {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    height: 26px;\n    opacity: 0;\n    animation: fadeIn 0.5s ease-out forwards;\n  }\n  .conversion-arrow:nth-child(2)  { animation-delay: 0.15s; }\n  .conversion-arrow:nth-child(4)  { animation-delay: 0.25s; }\n  .conversion-arrow:nth-child(6)  { animation-delay: 0.35s; }\n  .conversion-arrow:nth-child(8)  { animation-delay: 0.45s; }\n  .conversion-arrow:nth-child(10) { animation-delay: 0.55s; }\n  \n  @keyframes fadeIn {\n    to { opacity: 1; }\n  }\n  \n  .conv-rate {\n    font-size: 10px;\n    color: #94a3b8;\n    background: rgba(255,255,255,0.04);\n    padding: 2px 10px;\n    border-radius: 10px;\n    border: 1px solid rgba(255,255,255,0.06);\n  }\n  .conv-rate .arrow-icon {\n    display: inline-block;\n    margin-right: 4px;\n    color: #667eea;\n    font-size: 9px;\n  }\n  \n  .summary-bar {\n    display: flex;\n    justify-content: center;\n    gap: 20px;\n    margin-top: 24px;\n    flex-wrap: wrap;\n  }\n  .summary-item {\n    text-align: center;\n    padding: 8px 16px;\n    background: rgba(255,255,255,0.03);\n    border-radius: 8px;\n    border: 1px solid rgba(255,255,255,0.06);\n  }\n  .summary-item .val {\n    font-size: 20px;\n    font-weight: 700;\n    background: linear-gradient(135deg, #667eea, #764ba2);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n  .summary-item .lbl {\n    font-size: 10px;\n    color: #94a3b8;\n    margin-top: 2px;\n  }\n</style>\n</head>\n<body>\n  <div class=\"header\">\n    <h2>RECRUITMENT PIPELINE</h2>\n  </div>\n  \n  <div class=\"funnel-container\" id=\"funnel\">\n    <div class=\"funnel-stage\">\n      <div class=\"stage-label\"><span class=\"stage-name\">📥 Applied</span><span class=\"stage-count\">6</span></div>\n    </div>\n    <div class=\"conversion-arrow\"><span class=\"conv-rate\"><span class=\"arrow-icon\">▼</span>100%</span></div>\n    <div class=\"funnel-stage\">\n      <div class=\"stage-label\"><span class=\"stage-name\">🔍 Evaluated</span><span class=\"stage-count\">6</span></div>\n    </div>\n    <div class=\"conversion-arrow\"><span class=\"conv-rate\"><span class=\"arrow-icon\">▼</span>50%</span></div>\n    <div class=\"funnel-stage\">\n      <div class=\"stage-label\"><span class=\"stage-name\">✅ Strong</span><span class=\"stage-count\">3</span></div>\n    </div>\n    <div class=\"conversion-arrow\"><span class=\"conv-rate\"><span class=\"arrow-icon\">▼</span>17%</span></div>\n    <div class=\"funnel-stage\">\n      <div class=\"stage-label\"><span class=\"stage-name\">👍 Good</span><span class=\"stage-count\">1</span></div>\n    </div>\n    <div class=\"conversion-arrow\"><span class=\"conv-rate\"><span class=\"arrow-icon\">▼</span>17%</span></div>\n    <div class=\"funnel-stage\">\n      <div class=\"stage-label\"><span class=\"stage-name\">🤔 Potential</span><span class=\"stage-count\">1</span></div>\n    </div>\n    <div class=\"conversion-arrow\"><span class=\"conv-rate\"><span class=\"arrow-icon\">▼</span>17%</span></div>\n    <div class=\"funnel-stage\">\n      <div class=\"stage-label\"><span class=\"stage-name\">❌ Rejected</span><span class=\"stage-count\">1</span></div>\n    </div>\n  </div>\n  \n  <div class=\"summary-bar\">\n    <div class=\"summary-item\">\n      <div class=\"val\">83%</div>\n      <div class=\"lbl\">Pass Rate</div>\n    </div>\n    <div class=\"summary-item\">\n      <div class=\"val\">50%</div>\n      <div class=\"lbl\">Top Tier</div>\n    </div>\n    <div class=\"summary-item\">\n      <div class=\"val\">17%</div>\n      <div class=\"lbl\">Reject Rate</div>\n    </div>\n  </div>\n  \n  <script>\n    window.addEventListener('jet:refresh', (e) => {\n      const data = e.detail;\n      if (data && data.pipeline) {\n        const stages = document.querySelectorAll('.funnel-stage .stage-count');\n        data.pipeline.forEach((item, i) => {\n          if (stages[i]) stages[i].textContent = item.count;\n        });\n      }\n    });\n  </script>\n</body>\n</html>\n",
